generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum CoopRole {
  OWNER
  EDITOR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  // Demographics
  city            String?
  state           String?
  ageRange        String?
  gender          String?
  raceEthnicity   String?

  // Entrepreneurial readiness
  hasIdea         String?
  foundingGroup   String?
  biggestBarrier  String?
  readinessStage  String?
  workedAtCoop    String?
  wouldConvert    String?

  emailSubscribed Boolean  @default(false)

  accounts        Account[]
  sessions        Session[]
  coopMemberships CoopMember[]
}

model Coop {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         CoopMember[]
  handbookEntries HandbookEntry[]
}

model CoopMember {
  id     String   @id @default(cuid())
  coopId String
  userId String
  role   CoopRole @default(EDITOR)

  coop Coop @relation(fields: [coopId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coopId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model HandbookEntry {
  id        String   @id @default(cuid())
  coopId    String
  fieldId   String
  value     String
  updatedAt DateTime @updatedAt

  coop Coop @relation(fields: [coopId], references: [id], onDelete: Cascade)

  @@unique([coopId, fieldId])
}
